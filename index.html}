<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Menu Project</title>
    <style>
        body { display: flex; justify-content: center; gap: 15px; flex-wrap: wrap; background-color: #333; padding: 20px; font-family: sans-serif; }
        .menu-card { 
            width: 400px; height: 550px; margin: 15px; padding: 25px; 
            border: 8px double white; box-sizing: border-box; 
            color: white; border-radius: 10px;
            background-repeat: no-repeat; background-position: center; background-size: cover;
            text-shadow: 2px 2px 4px #000;
        }
        /* Ajuste de rutas para GitHub */
        .breakfast { background-image: url("Copia de Claude-Monet-The-Waterlily-Pond-with-the-Japanese-Bridge-1899.jpg"); }
        .lunch { background-image: url("Copia de MB-Mon-21_Monet_Steilkueste-von-Aval_1 2.jpg"); }
        .dinner { background-image: url("cc4512ce9e2845f140221c0baa3de41e.jpg"); }
        
        h1 { text-align: center; border-bottom: 2px solid white; margin-top: 0; }
        ul { list-style: none; padding: 0; margin-top: 50px; }
        li { margin-bottom: 20px; background: rgba(0,0,0,0.6); padding: 10px; border-radius: 5px; }
        strong { display: block; color: #f1c40f; }
    </style>
</head>
<body>
    <div class="menu-card breakfast">
        <h1>Breakfast</h1>
        <ul>
            <li><strong>Waterlily Eggs</strong><span>Omelette con hierbas.</span></li>
            <li><strong>Garden Toast</strong><span>Pan con mermelada.</span></li>
        </ul>
    </div>
    <div class="menu-card lunch">
        <h1>Lunch</h1>
        <ul>
            <li><strong>Cliffside Salad</strong><span>Vegetales frescos.</span></li>
            <li><strong>Ocean Salmon</strong><span>Salmón a la plancha.</span></li>
        </ul>
    </div>
    <div class="menu-card dinner">
        <h1>Dinner</h1>
        <ul>
            <li><strong>Silk Steak</strong><span>Corte en salsa de vino.</span></li>
            <li><strong>Velvet Pasta</strong><span>Pasta con trufa.</span></li>
        </ul>
    </div>
</body>
</html>
